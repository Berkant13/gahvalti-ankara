                },
                {
                  "type": "text",
                  "id": "Ww8pV",
                  "fill": "#6B4A2E",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Ankara şehir merkezine en yakın köylerden birinde, köy odalarında veya bahçede kahvaltı, yöresel lezzetler ve yöresel köy pazarında organik ürünleri tadına bakarak alma fırsatı sunuyoruz.",
                  "lineHeight": 1.75,
                  "fontFamily": "Merriweather",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
